# MongoDB Atlas (FREE tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=nexpass
MONGODB_LOCAL_MASTER_KEY=<run: node scripts/setup-mongodb.js>

# Appwrite (keep existing for now)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your-database-id
APPWRITE_API_KEY=your-api-key

# GoCardless
GC_SECRET_ID=your-gocardless-secret-id
GC_SECRET_KEY=your-gocardless-secret-key
GC_REDIRECT_URI=http://localhost:3000/link-bank/callback

# OpenAI (optional)
OPENAI_API_KEY=your-openai-api-key

# Environment
NODE_ENV=development
